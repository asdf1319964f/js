# Dockerfile.frontend
FROM nginx:alpine

# 复制前端静态文件
# *** 关键修正：添加 'frontend/' 前缀 ***
COPY frontend/public/*.html /usr/share/nginx/html/
COPY frontend/public/*.css /usr/share/nginx/html/
COPY frontend/public/*.js /usr/share/nginx/html/

# 复制Nginx配置
# *** 关键修正：添加 'frontend/' 前缀 ***
COPY frontend/nginx/default.conf /etc/nginx/conf.d/default.conf 

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
