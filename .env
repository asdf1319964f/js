# .env 文件示例 (请替换为您的实际值，特别是密钥！)

# MongoDB 凭据
MONGO_USERNAME=admin
MONGO_PASSWORD=password

# JWT 密钥 (强烈建议使用长且复杂的随机字符串)
JWT_SECRET=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2

# Telegram 会话加密密钥 (非常重要！强烈建议使用长且复杂的随机字符串)
TELEGRAM_SESSION_ENCRYPTION_KEY=c7a3f8b0e1d6c9b5a2e4d0c3b1a9f6e5

# 应用环境
NODE_ENV=development # 或 production

# CORS 允许的来源 (开发环境可以是 http://localhost:8086, 生产环境必须是你的前端域名)
CORS_ORIGIN=http://localhost:8086